# Host configuration for all platform services and apps.
# Copy relevant sections to each service's .env file,
# or export these vars in your shell before running bootstrap/deploy.
#
# Defaults (homelab.local) are built into each compose file —
# only set these if you're using a different domain.
#
# For a single domain (e.g. yourdomain.com), replace homelab.local everywhere:
#   sed 's/homelab.local/yourdomain.com/g' hosts.env.example > hosts.env
#
# For different apps on different domains, set each var individually.

# ── Platform infrastructure ───────────────────────────────────────────────────
TRAEFIK_HOST=traefik.homelab.local
PORTAINER_HOST=portainer.homelab.local
GRAFANA_HOST=monitoring.homelab.local
INFISICAL_HOST=secrets.homelab.local
VERDACCIO_HOST=npm.homelab.local
UPTIME_KUMA_HOST=status.homelab.local
UMAMI_HOST=analytics.homelab.local
GARAGE_HOST=s3.homelab.local

# ── Shared services ───────────────────────────────────────────────────────────
AUTH_SERVICE_HOST=auth.homelab.local
AI_SHIM_HOST=aishim.homelab.local
DOC_BUCKET_HOST=docbucket.homelab.local
EMAIL_SERVICE_HOST=mail.homelab.local
